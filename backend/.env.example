# ==============================
# CuratiX Vault — Backend .env
# ==============================
# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# --- MySQL (Aiven) ---
DB_URL=jdbc:mysql://<aiven-host>:<port>/defaultdb?ssl-mode=REQUIRED&useSSL=true&serverTimezone=UTC
DB_USER=avnadmin
DB_PASS=<your-aiven-password>

# --- Firebase Admin SDK ---
FIREBASE_PROJECT_ID=<your-firebase-project-id>
# Path to your firebase-adminsdk.json file.
# Option 1: place it in src/main/resources/ and use classpath:firebase-adminsdk.json (default)
# Option 2: place it anywhere and set the absolute path here
FIREBASE_CREDENTIALS_PATH=classpath:firebase-adminsdk.json

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# --- Server ---
PORT=8080
